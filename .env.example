# Copy to `.env` and fill in.

# Local SQLite database. The default works out of the box.
DATABASE_URL="file:./dev.db"

# Production (hosted) database via Turso. When TURSO_DATABASE_URL is set it is
# used instead of DATABASE_URL — the same libSQL adapter handles both. Create a
# free database at https://turso.tech, then run `npm run db:turso` once to apply
# the schema. Leave these blank for local development.
TURSO_DATABASE_URL=""
TURSO_AUTH_TOKEN=""

# --- AI provider (optional) -------------------------------------------------
# Enables the thinking-partner, reflections, quick-capture sorting, and graph
# insight. Set ANY ONE key below; the app auto-selects in this order:
# Groq -> OpenRouter -> Gemini. Without a key, AI features fall back to local
# heuristics and the app stays fully usable.

# Groq — recommended: fast + generous free tier. https://console.groq.com/keys
GROQ_API_KEY=""

# OpenRouter — access to many models incl. free ones. https://openrouter.ai/keys
OPENROUTER_API_KEY=""

# Google Gemini — free tier rate-limits easily (HTTP 429). https://aistudio.google.com/apikey
GEMINI_API_KEY=""

# Optional: force a provider regardless of which keys are set.
# AI_PROVIDER="groq"   # groq | openrouter | gemini

# Optional model overrides (sensible defaults are built in):
# GROQ_MODEL="llama-3.3-70b-versatile"
# OPENROUTER_MODEL="meta-llama/llama-3.3-70b-instruct:free"
# GEMINI_MODEL="gemini-2.0-flash"

