# Copy to `.env` and fill in.

# Local SQLite database. The default works out of the box.
DATABASE_URL="file:./dev.db"

# Production (hosted) database via Turso. When TURSO_DATABASE_URL is set it is
# used instead of DATABASE_URL — the same libSQL adapter handles both. Create a
# free database at https://turso.tech, then run `npm run db:turso` once to apply
# the schema. Leave these blank for local development.
TURSO_DATABASE_URL=""
TURSO_AUTH_TOKEN=""

# --- AI engine (optional) ---------------------------------------------------
# Enables the thinking-partner, reflections, quick-capture sorting, and graph
# insight. Set as MANY providers as you like — the engine tries them in order
# until one answers, so a rate-limited (429) or down provider falls through to
# the next automatically. Without any key, AI falls back to local heuristics.
#
# Default try order: Groq -> OpenRouter -> Cerebras -> Mistral -> Together -> Gemini
#
# Tip: give one provider MULTIPLE keys (comma-separated) to rotate around
# per-key rate limits:  GROQ_API_KEY="key_one,key_two"

GROQ_API_KEY=""        # recommended: fast + generous free tier. https://console.groq.com/keys
OPENROUTER_API_KEY=""  # many models incl. free ones.            https://openrouter.ai/keys
CEREBRAS_API_KEY=""    # very fast free tier.                    https://cloud.cerebras.ai
MISTRAL_API_KEY=""     # free tier.                              https://console.mistral.ai
TOGETHER_API_KEY=""    # free + paid models.                     https://api.together.ai
GEMINI_API_KEY=""      # free tier rate-limits easily (429).     https://aistudio.google.com/apikey

# Optional: reorder or pin providers.
# AI_PROVIDER_ORDER="mistral,groq,gemini"   # custom fallback order
# AI_PROVIDER="groq"                         # force exactly one

# Optional model overrides (sensible defaults are built in):
# GROQ_MODEL="llama-3.3-70b-versatile"
# OPENROUTER_MODEL="meta-llama/llama-3.3-70b-instruct:free"
# CEREBRAS_MODEL="llama-3.3-70b"
# MISTRAL_MODEL="mistral-small-latest"
# TOGETHER_MODEL="meta-llama/Llama-3.3-70B-Instruct-Turbo-Free"
# GEMINI_MODEL="gemini-2.0-flash"

