# Copy to `.env` and fill in.

# Local SQLite database. The default works out of the box.
DATABASE_URL="file:./dev.db"

# Production (hosted) database via Turso. When TURSO_DATABASE_URL is set it is
# used instead of DATABASE_URL — the same libSQL adapter handles both. Create a
# free database at https://turso.tech, then run `npm run db:turso` once to apply
# the schema. Leave these blank for local development.
TURSO_DATABASE_URL=""
TURSO_AUTH_TOKEN=""

# Optional: enables the AI thinking-partner, reflections, and connection insight.
# Get a free key at https://aistudio.google.com/apikey
# Without it, every AI feature falls back to a local heuristic and the app stays
# fully usable.
GEMINI_API_KEY=""

# Optional: override the Gemini model (defaults to gemini-2.0-flash).
# GEMINI_MODEL="gemini-2.0-flash"
