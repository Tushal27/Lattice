<?xml version="1.0" encoding="utf-8"?>
<!-- Copy to: android/app/src/main/res/layout/activity_lattice_settings.xml -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0a0a0b">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Lattice · SMS capture"
            android:textColor="#fafafa"
            android:textSize="20sp"
            android:textStyle="bold"
            android:paddingBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Where payment SMS are forwarded. Change anytime — no rebuild needed."
            android:textColor="#a1a1aa"
            android:textSize="13sp"
            android:paddingBottom="12dp" />

        <TextView
            android:id="@+id/permStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="13sp"
            android:paddingBottom="12dp" />

        <Button
            android:id="@+id/grant"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Grant SMS permission"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Webhook URL"
            android:textColor="#d4d4d8"
            android:textSize="13sp" />

        <EditText
            android:id="@+id/url"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="https://your-app.vercel.app/api/sms"
            android:textColor="#fafafa"
            android:textColorHint="#52525b"
            android:inputType="textUri"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Secret (SMS_INGEST_SECRET / CRON_SECRET)"
            android:textColor="#d4d4d8"
            android:textSize="13sp" />

        <EditText
            android:id="@+id/secret"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="your-secret"
            android:textColor="#fafafa"
            android:textColorHint="#52525b"
            android:inputType="textPassword"
            android:layout_marginBottom="24dp" />

        <Button
            android:id="@+id/save"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Save"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/test"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Send test" />
    </LinearLayout>
</ScrollView>
