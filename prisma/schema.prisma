// Lattice — a personal operating system.
// Everything the user captures is an `Entry`. The `type` field discriminates
// between decisions, lessons, aha moments, questions, and projects. Structured,
// type-specific data lives in the JSON `fields` column so each area can evolve
// its own shape without schema churn. Cross-area `Connection`s and shared `Tag`s
// turn isolated notes into a network of understanding.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Entry {
  id         String    @id @default(cuid())
  type       String // decision | lesson | aha | question | project
  title      String
  summary    String? // short human-readable body / context line
  status     String? // question: open|exploring|answered — project: active|paused|done
  confidence Int? // 0-100, primarily for decisions
  fields     String? // JSON blob of type-specific structured fields
  embedding  String? // JSON float[] semantic vector (optional; for similarity)
  occurredAt DateTime? // when it actually happened (drives the life timeline)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  // A project is itself an Entry; other entries can belong to it.
  projectId String?
  project   Entry?  @relation("ProjectEntries", fields: [projectId], references: [id], onDelete: SetNull)
  children  Entry[] @relation("ProjectEntries")

  tags EntryTag[]

  connectionsFrom Connection[] @relation("FromEntry")
  connectionsTo   Connection[] @relation("ToEntry")

  @@index([type])
  @@index([occurredAt])
}

model Tag {
  id      String     @id @default(cuid())
  name    String     @unique
  entries EntryTag[]
}

model EntryTag {
  entryId String
  tagId   String
  entry   Entry  @relation(fields: [entryId], references: [id], onDelete: Cascade)
  tag     Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([entryId, tagId])
  @@index([tagId])
}

model Connection {
  id        String   @id @default(cuid())
  fromId    String
  toId      String
  note      String? // why these two relate
  createdAt DateTime @default(now())

  from Entry @relation("FromEntry", fields: [fromId], references: [id], onDelete: Cascade)
  to   Entry @relation("ToEntry", fields: [toId], references: [id], onDelete: Cascade)

  @@unique([fromId, toId])
  @@index([toId])
}

// A follow-through item that emerges from knowledge (a decision to review, a
// question to research, a habit). sourceId loosely references an Entry.
model Commitment {
  id            String    @id @default(cuid())
  title         String
  description   String?
  status        String    @default("open") // open | done | cancelled
  dueDate       DateTime?
  completedAt   DateTime?
  recurringRule String? // daily | weekly | monthly | weekly:mon …
  priority      String? // low | medium | high
  sourceType    String? // decision | lesson | aha | question | project | manual
  sourceId      String? // related entry id (loose reference)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([status])
  @@index([dueDate])
}

// A proactive nudge surfaced from the user's data (a decision ready to review,
// a forgotten question, an emerging interest, a repeated pattern…). Generated
// idempotently from a stable `key`; dismissals persist so it won't nag again.
model InsightTrigger {
  id        String   @id @default(cuid())
  key       String   @unique // stable dedup key, e.g. "decision-review:<entryId>"
  type      String // DecisionReviewReady | ForgottenQuestion | RepeatedPattern | EmergingInterest | MistakeWarning | ProjectStalled | CommitmentOpportunity
  title     String
  body      String?
  entityId  String? // related entry id, if any
  priority  Int      @default(0)
  status    String   @default("active") // active | dismissed | acted
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

// A browser Web Push subscription (one per device/browser). Optional: if no
// VAPID keys are configured the app simply falls back to in-app nudges.
model PushSubscription {
  id        String   @id @default(cuid())
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
}

// Generic key-value store for app-level state that isn't an entry — e.g. the
// Google OAuth token bundle, sync cursors, and capability trust settings.
model AppState {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// Provenance for ingested knowledge — every entry created from an external
// source (a file, a web page, a GitHub repo) records where it came from, so the
// same item is never ingested twice and "show original" stays possible.
model Source {
  id         String   @id @default(cuid())
  provider   String // file | url | github
  externalId String? // url, repo full name, content hash — used for dedupe
  title      String
  entryId    String? // the entry distilled from this source
  createdAt  DateTime @default(now())

  @@index([provider])
}

// Append-only audit trail of everything the assistant DOES on the user's behalf
// — every write, every outward action (calendar event, inbox capture). This is
// what makes autonomy trustworthy: nothing happens that isn't recorded here.
model ActionLog {
  id         String   @id @default(cuid())
  capability String // create_entry | create_commitment | calendar.create_event | gmail.capture | ...
  summary    String
  status     String   @default("done") // done | failed | proposed
  source     String   @default("agent") // agent | gmail | calendar | cron | autonomous | user
  entityId   String? // related entry/commitment/event id, if any
  createdAt  DateTime @default(now())

  @@index([createdAt])
}

